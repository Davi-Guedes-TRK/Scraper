# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local — ele está no .gitignore.

# ── Supabase (público — seguro expor no client) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase (servidor — NUNCA expor no client) ──────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string (Session mode)
DATABASE_URL=postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── IA ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Scraper (chave interna para autenticar POST /api/imoveis) ────────────────
SCRAPER_API_KEY=gere_com_openssl_rand_hex_32

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── Pipefy ───────────────────────────────────────────────────────────────────
# Token Keycloak (~3 dias de validade). Renovar: python scripts/pipefy_auth_setup.py
PIPEFY_TOKEN=eyJ...
PIPEFY_PIPE_ID=307179010

# ── Cartório — e-mail automatizado (Google Apps Script) ─────────────────────
# 1. Cole o código de scripts/cartorio_apps_script.js em script.google.com
# 2. Publique como "App da web" (Executar como: Eu, Acesso: Qualquer pessoa)
# 3. Copie a URL gerada abaixo
APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec
# Segredo compartilhado entre o app e o Apps Script (qualquer string aleatória)
APPS_SCRIPT_SECRET=trk-cartorio-2024

# Segredo do webhook de inbound — o Apps Script inclui esse token na URL ao chamar o app
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
INBOUND_WEBHOOK_SECRET=gere_com_python_secrets_token_hex_32

# ── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_ORG=trk-imoveis
SENTRY_PROJECT=erp-trk
# SENTRY_AUTH_TOKEN=sntrys_XXXX  ← pegar em sentry.io → Settings → Auth Tokens

# ── Email (Resend — opcional, não usado no fluxo atual) ─────────────────────
RESEND_API_KEY=re_...

# ── Pipefy webhook (chave para /api/pipefy) ──────────────────────────────────
# Pode reusar o SCRAPER_API_KEY ou definir separado
PIPEFY_API_KEY=mesmo_valor_do_scraper_api_key
